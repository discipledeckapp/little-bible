generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  CONTENT_EDITOR
  THEOLOGICAL_REVIEWER
  CURRICULUM_MANAGER
  SUPPORT_ADMIN
  ANALYTICS_VIEWER
}

// ── NextAuth required tables ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime   @default(now())
  role          AdminRole?
  accounts      Account[]
  sessions      Session[]
  progress      UserProgress?
  donations     Donation[]
  family        Family?
  auditLogs     AdminAuditLog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App data ─────────────────────────────────────────────────────────────────

model UserProgress {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wisdomSeeds          Int      @default(0)
  streak               Int      @default(0)
  lastActiveDate       String   @default("")
  completedVersesJson  String   @default("{}") @db.Text
  completedChapters    String[] @default([])
  badgesJson           String   @default("[]") @db.Text
  sessionsJson         String   @default("[]") @db.Text
  updatedAt            DateTime @updatedAt
}

// ── Family Identity System ────────────────────────────────────────────────────

model Family {
  id         String   @id @default(cuid())
  name       String?
  ownerId    String   @unique
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members    FamilyMember[]
  streak     FamilyStreak?
  prayers    FamilyPrayer[]
  milestones FamilyMilestone[]
  journeyId  String?
  createdAt  DateTime @default(now())
}

model FamilyMember {
  id          String   @id @default(cuid())
  familyId    String
  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  name        String
  age         Int?
  avatarId    String   @default("lion")
  accentColor String?
  faithGoals  String[] @default([])
  seeds       Int      @default(0)
  sortOrder   Int      @default(0)
  progress    MemberProgress?
  sessions    MemberSession[]
  createdAt   DateTime @default(now())
}

model MemberProgress {
  id                  String   @id @default(cuid())
  memberId            String   @unique
  member              FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  completedVersesJson String   @default("{}") @db.Text
  completedChapters   String[] @default([])
  memoryVersesJson    String   @default("[]") @db.Text
  lastReadBook        String?
  lastReadChapter     Int?
  lastReadAt          DateTime?
  updatedAt           DateTime @updatedAt
}

model MemberSession {
  id       String   @id @default(cuid())
  memberId String
  member   FamilyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  bookSlug String
  chapter  Int
  verse    Int
  mode     String
  readAt   DateTime @default(now())
}

model FamilyStreak {
  id            String   @id @default(cuid())
  familyId      String   @unique
  family        Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastReadDate  String   @default("")
  updatedAt     DateTime @updatedAt
}

model FamilyPrayer {
  id         String   @id @default(cuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  memberId   String?
  bookSlug   String
  chapter    Int
  verse      Int
  prayerText String   @db.Text
  answered   Boolean  @default(false)
  savedAt    DateTime @default(now())
}

model FamilyMilestone {
  id         String   @id @default(cuid())
  familyId   String
  family     Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  memberId   String?
  type       String
  achievedAt DateTime @default(now())
}

// ── Donations ─────────────────────────────────────────────────────────────────

model Donation {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  amount     Int      // in smallest unit (cents / kobo)
  currency   String   // 'usd' | 'ngn'
  provider   String   // 'stripe' | 'paystack'
  status     String   @default("pending") // 'pending' | 'completed' | 'failed'
  reference  String?  @unique
  createdAt  DateTime @default(now())
}

// ── Admin ─────────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  isGuest   Boolean  @default(false)
  bookSlug  String?
  chapter   Int?
  verseNum  Int?
  storyId   String?
  mode      String?
  props     Json?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([bookSlug, chapter])
  @@index([createdAt])
}

model ContentReview {
  id         String   @id @default(cuid())
  bookSlug   String
  chapter    Int
  verseNum   Int?
  status     String   @default("pending") // pending | approved | needs_revision | flagged
  concern    String?  // theological | too_difficult | language | other
  notes      String?  @db.Text
  reviewerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([bookSlug, chapter, verseNum])
  @@index([status])
  @@index([bookSlug, chapter])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  action    String
  targetId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([createdAt])
}
